# Contact form — required for /api/contact to send email
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Where contact form submissions are sent (defaults to hello@qtvue.com)
CONTACT_EMAIL_TO=hello@qtvue.com

# Public site URL (used for canonical URLs, sitemap, OG tags)
NUXT_PUBLIC_SITE_URL=https://qtvue.com
